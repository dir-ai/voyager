{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.dir-ai/voyager",
  "description": "Cited, OSV-gated, injection-hardened web briefs for coding agents. Verified, never raw web.",
  "version": "1.1.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@dir-ai/voyager",
      "version": "1.1.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "valueHint": "subcommand",
          "value": "mcp"
        }
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/dir-ai/voyager",
    "source": "github"
  }
}
